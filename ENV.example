# Aurum API and deployment environment variables
# Fill required keys first, then optional ones.

# Required API keys
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
FRED_KEY=your_fred_key_here
NEWS_API_KEY=your_newsapi_key_here
METALS_DEV_KEY=your_metals_dev_key_here

# Optional API key (pipeline works without it, but recommended)
COINGECKO_KEY=your_coingecko_demo_key_here

# Required for production Gist pipeline mode (not needed for --dry-run)
GIST_ID=your_gist_id_here
GIST_TOKEN=your_github_token_with_gist_scope_here

# Optional deploy hook (for forcing Netlify rebuilds)
NETLIFY_BUILD_HOOK=your_netlify_build_hook_url_here

# Keyless sources used by fetch.js (no key required)
# - Fear and Greed: api.alternative.me
# - FX rates: open.er-api.com
# - Gold CSV fallback: freegoldapi.com
# - Geopolitical feed: api.gdeltproject.org
